# ──────────────────────────────────────────────────────────────
# Sentinal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ──────────────────────────────────────────────────────────────

# ── Gemini API ─────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyC4fK2paDPWfZC4ZOhOEx3oeUjqb4_1mhI

# Model options:
#   gemini-1.5-flash   → fast, cheap, good for hackathons ✅
#   gemini-1.5-pro     → more capable, slower, higher quota cost
#   gemini-2.0-flash   → newest, fast (if available on your key)
GEMINI_MODEL=gemini-1.5-flash

# ── Resilience ─────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=1.0   # seconds; doubles with each attempt (exponential backoff)

# ── Database ────────────────────────────────────────────────────
# SQLite (default — works everywhere, no setup needed)
DB_PATH=sentinal.db

# AlloyDB / Cloud SQL PostgreSQL (optional — uncomment and fill for GCP)
# DB_TYPE=postgres
# DB_HOST=/cloudsql/YOUR_PROJECT:REGION:INSTANCE
# DB_NAME=sentinal
# DB_USER=postgres
# DB_PASS=your_password

# ── App ─────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=false

# ── Memory ──────────────────────────────────────────────────────
# How many past sessions to inject into each new prompt for memory-awareness
CONTEXT_LOG_LIMIT=3
